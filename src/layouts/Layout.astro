---
import '../styles/global.css';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import PersistentPlayer from '@/components/audio/PersistentPlayer.astro';
import CartDrawer from '@/components/cart/CartDrawer.astro';
import { ClientRouter } from 'astro:transitions';
import BaseSeo from '@/components/seo/BaseSeo.astro';
import ReligiousOrganizationSchema from '@/components/seo/ReligiousOrganizationSchema.astro';
import MetaSocial from '@/components/seo/MetaSocial.astro';

interface Props {
  title?: string;
  description?: string;
  locale?: 'es' | 'en' | 'pt';
}

const {
  title = 'CEPSERIS',
  description = 'Centro e Pronto Socorro Espiritual Raimundo Irineu Serra. Igreja da Doutrina de Santo Daime.',
  locale = 'pt',
} = Astro.props;

const fullTitle = title === 'CEPSERIS' ? title : `${title} | CEPSERIS`;
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <BaseSeo title={title} description={description} locale={locale} />
    <MetaSocial title={fullTitle} description={description} locale={locale} />
    <ReligiousOrganizationSchema />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{fullTitle}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col bg-canvas text-primary antialiased">
    <Navbar locale={locale} />
    <CartDrawer />
    <main class="flex-1">
      <slot />
    </main>
    <PersistentPlayer />
    <Footer locale={locale} />
  </body>
</html>
