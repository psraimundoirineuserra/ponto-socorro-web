---
import Layout from '@/layouts/Layout.astro';
import CategoryPills from '@/components/library/CategoryPills.astro';
import HymnsGrid from '@/components/library/HymnsGrid.astro';
import { useTranslations } from '@/i18n';
import { cadernos, hymns } from '@/data/hymns';

const locale = 'es';
const t = useTranslations(locale);
const currentFilter = Astro.url.searchParams.get('filter') || 'all';

const categories = [
  { name: t.library.all, value: 'all', count: hymns.length },
  ...cadernos.map(c => ({ name: c.name, value: c.slug, count: hymns.filter(h => h.caderno === c.slug).length }))
];

const filteredHymns = currentFilter === 'all'
  ? hymns
  : hymns.filter(h => h.caderno === currentFilter);
---

<Layout locale={locale} title={t.library.title} description={t.library.subtitle}>
  <section class="py-16 px-6">
    <div class="max-w-6xl mx-auto">
      <h1 class="font-serif text-4xl font-semibold text-primary mb-4">
        {t.library.title}
      </h1>
      <p class="text-secondary mb-12">{t.library.subtitle}</p>
      
      <CategoryPills categories={categories} currentFilter={currentFilter} />
      
      <div class="mt-12">
        <HymnsGrid hymns={filteredHymns} />
      </div>
    </div>
  </section>
</Layout>