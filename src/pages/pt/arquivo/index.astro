---
import Layout from '@/layouts/Layout.astro';
import { useTranslations } from '@/i18n';
import Timeline from '@/components/archive/Timeline.astro';
import DimensionTabs from '@/components/archive/DimensionTabs.astro';
import VideoCard from '@/components/archive/VideoCard.astro';
import GalleryPlaceholder from '@/components/archive/GalleryPlaceholder.astro';
import { archiveVideos } from '@/data/archive-videos';

const locale = 'pt';
const t = useTranslations(locale as 'pt' | 'es' | 'en');

const translations = {
  pt: {
    title: 'Arquivo',
    subtitle: 'Preservação e Memória',
    timelineTitle: 'O Fio da Memória',
    videosTitle: 'Videos do Canal',
    dimensionsTitle: 'Dimensões',
    galleryTitle: 'A Arca das Imagens',
    timelineNodes: [
      { year: '2007', title: 'Fundação e Relato', desc: 'Chegada à Vila Carneiro e crónicas de O Peregrino. Início da documentação da história do CEPSERIS.' },
      { year: '2011', title: 'Expansão Doutrinal', desc: 'Consolidação de blogs e registros do Padrinho Nonato. Presença digital começa a se formar.' },
      { year: '2012', title: 'Ano Acadêmico', desc: 'Tese USP sobre controvérsia ayahuasca. Registros audiovisuais em Acre ganham força.' },
      { year: '2016', title: 'Crescimento Digital', desc: 'Digitalização de calendários e expansão em redes sociais. Facebook e Instagram ativos.' },
      { year: '2022', title: 'Consolidação Territorial', desc: 'Censo Comunitário da Colônia Cinco Mil. Diagnóstico oficial do território.' },
      { year: '2023-25', title: 'Presente/Evolução', desc: 'Estudos etnográficos e processos contemporâneos. CEPSERIS reconhecido globalmente.' }
    ],
    dimensions: [
      { id: 'I' as const, label: 'O Trono do Saber', count: 11 },
      { id: 'II' as const, label: 'A Memória Viva', count: 4 },
      { id: 'III' as const, label: 'O Olhar da Floresta', count: 5 },
      { id: 'IV' as const, label: 'A Bitácora Digital', count: 14 }
    ],
    dimensionLabels: {
      I: 'O Trono do Saber',
      II: 'A Memória Viva',
      III: 'O Olhar da Floresta',
      IV: 'A Bitácora Digital'
    }
  },
  es: {
    title: 'Archivo',
    subtitle: 'Preservación y Memoria',
    timelineTitle: 'El Hilo de la Memoria',
    videosTitle: 'Videos del Canal',
    dimensionsTitle: 'Dimensiones',
    galleryTitle: 'El Arca de las Imágenes',
    timelineNodes: [
      { year: '2007', title: 'Fundación y Relato', desc: 'Llegada a Vila Carneiro y crónicas de O Peregrino. Inicio de la documentación.' },
      { year: '2011', title: 'Expansión Doctrinal', desc: 'Consolidación de blogs y registros de Padrinho Nonato.' },
      { year: '2012', title: 'Año Académico', desc: 'Tesis USP sobre controversia ayahuasca. Registros en Acre.' },
      { year: '2016', title: 'Crecimiento Digital', desc: 'Digitalización y expansión en redes sociales.' },
      { year: '2022', title: 'Consolidación Territorial', desc: 'Censo Comunitario de Colônia Cinco Mil.' },
      { year: '2023-25', title: 'Presente/Evolución', desc: 'Reconocimiento global del CEPSERIS.' }
    ],
    dimensions: [
      { id: 'I' as const, label: 'El Trono del Saber', count: 11 },
      { id: 'II' as const, label: 'La Memoria Viva', count: 4 },
      { id: 'III' as const, label: 'La Mirada de la Selva', count: 5 },
      { id: 'IV' as const, label: 'La Bitácora Digital', count: 14 }
    ],
    dimensionLabels: {
      I: 'El Trono del Saber',
      II: 'La Memoria Viva',
      III: 'La Mirada de la Selva',
      IV: 'La Bitácora Digital'
    }
  },
  en: {
    title: 'Archive',
    subtitle: 'Preservation and Memory',
    timelineTitle: 'The Thread of Memory',
    videosTitle: 'Channel Videos',
    dimensionsTitle: 'Dimensions',
    galleryTitle: 'The Image Ark',
    timelineNodes: [
      { year: '2007', title: 'Founding and Narrative', desc: 'Arrival at Vila Carneiro and chronicles of O Peregrino.' },
      { year: '2011', title: 'Doctrinal Expansion', desc: 'Blog consolidation and Padrinho Nonato records.' },
      { year: '2012', title: 'Academic Year', desc: 'USP thesis on ayahuasca controversy. Acre records.' },
      { year: '2016', title: 'Digital Growth', desc: 'Calendar digitization and social media expansion.' },
      { year: '2022', title: 'Territorial Consolidation', desc: 'Community Census of Colônia Cinco Mil.' },
      { year: '2023-25', title: 'Present/Evolution', desc: 'Global recognition of CEPSERIS.' }
    ],
    dimensions: [
      { id: 'I' as const, label: 'The Throne of Knowledge', count: 11 },
      { id: 'II' as const, label: 'Living Memory', count: 4 },
      { id: 'III' as const, label: 'The Eyes of the Forest', count: 5 },
      { id: 'IV' as const, label: 'The Digital Logbook', count: 14 }
    ],
    dimensionLabels: {
      I: 'The Throne of Knowledge',
      II: 'Living Memory',
      III: 'The Eyes of the Forest',
      IV: 'The Digital Logbook'
    }
  }
};

const content = translations[locale as keyof typeof translations];
---

<Layout locale={locale} title={content.title} description={content.subtitle}>
  <section class="py-16 px-6">
    <div class="max-w-6xl mx-auto">
      {/* Header */}
      <header class="mb-16">
        <h1 class="font-serif text-4xl md:text-5xl font-semibold text-primary mb-4">
          {content.title}
        </h1>
        <p class="text-lg text-secondary">
          {content.subtitle}
        </p>
      </header>

      {/* Timeline + Videos */}
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 mb-16">
        {/* Timeline Sidebar */}
        <aside class="lg:col-span-1">
          <h2 class="text-xs font-medium uppercase tracking-wider text-secondary mb-6">
            {content.timelineTitle}
          </h2>
          <Timeline nodes={content.timelineNodes} activeYear="2012" />
        </aside>

        {/* Videos Content */}
        <div class="lg:col-span-2">
          <h2 class="font-serif text-2xl font-semibold text-primary mb-6">
            {content.videosTitle} @pd.raimundononato3780
          </h2>
          
          {/* All 18 Videos */}
          <VideoCard dimension="all" />
        </div>
      </div>

      {/* Dimension Tabs */}
      <div class="mb-12">
        <h2 class="text-xs font-medium uppercase tracking-wider text-secondary mb-6">
          {content.dimensionsTitle}
        </h2>
        <DimensionTabs dimensions={content.dimensions} activeDimension="II" />
      </div>

      {/* Gallery Placeholder */}
      <div class="mb-12">
        <h2 class="font-serif text-2xl font-semibold text-primary mb-6">
          {content.galleryTitle}
        </h2>
        <GalleryPlaceholder message="Galeria de fotos em desenvolvimento - implementação futura" />
      </div>

      {/* Dimension Content Info */}
      <div class="bg-surface border border-subtle rounded-lg p-8">
        <h3 class="font-serif text-xl font-semibold text-primary mb-4">
          Sobre as Dimensões
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-sm text-secondary">
          <div>
            <h4 class="font-medium text-primary mb-2">I. O Trono do Saber</h4>
            <p>Artigos acadêmicos, teses e estudos sobre o CEPSERIS. 11 itens de alta relevância acadêmica.</p>
          </div>
          <div>
            <h4 class="font-medium text-primary mb-2">II. A Memória Viva</h4>
            <p>Crônicas, blogs e registros históricos da comunidade. 4 itens narrativos fundamentais.</p>
          </div>
          <div>
            <h4 class="font-medium text-primary mb-2">III. O Olhar da Floresta</h4>
            <p>Conteúdo audiovisual - reportagens, vídeos e registros em mídia. 5 itens multimídia.</p>
          </div>
          <div>
            <h4 class="font-medium text-primary mb-2">IV. A Bitácora Digital</h4>
            <p>Presença em redes sociais - Facebook e Instagram. 14 itens de interação social.</p>
          </div>
        </div>
      </div>

      {/* YouTube Channel Link */}
      <div class="mt-12 text-center">
        <a 
          href="https://www.youtube.com/@pd.raimundononato3780" 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-red-600 text-white rounded-full hover:bg-red-700 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          Canal @pd.raimundononato3780 no YouTube
        </a>
      </div>
    </div>
  </section>
</Layout>