---
import Layout from '@/layouts/Layout.astro';
import { useTranslations } from '@/i18n';
import { dimensions, getDimensionById } from '@/data/archive-dimensions';
import { archiveVideos, getVideoThumbnailUrl, getVideoYoutubeUrl, formatViews } from '@/data/archive-videos';

const locale = 'pt';

const timelineFases = [
  {
    fase: 'I',
    nome: 'Raiz',
    periodo: '1892-1971',
    eventos: [
      { ano: '1892', evento: 'Nascimento de Raimundo Irineu Serra' },
      { ano: '1912', evento: 'Chegada ao Acre' },
      { ano: '1914', evento: 'Primeiro encontro com Ayahuasca' },
      { ano: '1916', evento: 'Iniciacao Xamanica' },
      { ano: '1920', evento: 'Deslocamento para Rio Branco' },
      { ano: '1930', evento: 'Fundacao do CRF' },
      { ano: '1935', evento: 'Primeiro Hinario Oficial' },
      { ano: '1945', evento: 'Estabelecimento no Alto Santo' },
      { ano: '1954', evento: 'Falecimento de Joao Pereira' },
      { ano: '1956', evento: 'Casamento Civil' },
      { ano: '1962', evento: 'Ingresso de Wilson Carneiro' },
      { ano: '1963', evento: 'Fundacao do CICLU' },
      { ano: '1966', evento: 'Criacao do Pronto Socorro' },
      { ano: '1971', evento: 'Falecimento de Mestre Irineu' }
    ]
  },
  {
    fase: 'II',
    nome: 'Transicao e Especializacao',
    periodo: '1972-2006',
    eventos: [
      { ano: '1974', evento: 'Fundacao da Colonia Cinco Mil' },
      { ano: '1975', evento: 'Primeira Igreja de Alvenaria' },
      { ano: '1986', evento: 'Publicacao Santo Daime: Cultura Amazonica' },
      { ano: '1988', evento: 'Criacao do CEFLUWCS' },
      { ano: '1989', evento: 'Administracao Raimundo Nonato' },
      { ano: '1992', evento: 'Centenario de Mestre Irineu' },
      { ano: '1997', evento: 'Inauguracao do CEPSERIS' },
      { ano: '1998', evento: 'Falecimento de Padrinho Wilson' },
      { ano: '2002', evento: 'Centro Estrela do Mar' },
      { ano: '2004', evento: 'I Encontro dos Prontos Socorros' }
    ]
  },
  {
    fase: 'III',
    nome: 'Academica e Digital',
    periodo: '2007-2026',
    eventos: [
      { ano: '2012', evento: 'Tese de Henrique Fernandes Antunes' },
      { ano: '2018', evento: 'Publicacao de Julia Moura' },
      { ano: '2022', evento: 'Censo Comunitaria' },
      { ano: '2023', evento: 'Tese de Julia Lobato Pinto de Moura' },
      { ano: '2025', evento: 'Reforma Integral da Sede Central' },
      { ano: '2026', evento: 'Lancamento de cepseris.org' }
    ]
  }
];

const canalVideos = archiveVideos.filter(v => v.source === 'canal').sort((a, b) => b.views - a.views);
const outroVideos = archiveVideos.filter(v => v.source === 'outro').sort((a, b) => b.views - a.views);

const dimIItems = dimensions.find(d => d.id === 'I')?.items || [];
const dimIIIItems = dimensions.find(d => d.id === 'III')?.items || [];
const dimIVItems = dimensions.find(d => d.id === 'IV')?.items || [];
---

<Layout locale={locale} title="Arquivo" description="Preservacao e Memoria">
  <section class="py-16 px-6">
    <div class="max-w-6xl mx-auto">
      <header class="mb-12">
        <h1 class="font-serif text-4xl font-semibold text-primary mb-2">Arquivo</h1>
        <p class="text-lg text-secondary">Preservacao e Memoria</p>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <aside class="lg:col-span-1">
          <h2 class="text-xs font-medium uppercase tracking-wider text-secondary mb-6">O Fio da Memoria</h2>
          <div class="relative pl-6 border-l border-subtle">
            {timelineFases.map((fase, fi) => (
              <div class="mb-8">
                <p class="text-xs font-medium text-accent-nature mb-2">Fase {fase.fase}: {fase.nome}</p>
                {fase.eventos.map((evt, ei) => (
                  <div class="relative mb-4">
                    <div class={`absolute -left-[13px] w-2 h-2 rounded-full ${(fi === 2 && ei === 0) ? 'bg-accent-nature' : 'bg-primary'}`}></div>
                    <p class="text-xs text-secondary mb-0.5">{evt.ano}</p>
                    <p class="text-sm font-medium text-primary">{evt.evento}</p>
                  </div>
                ))}
              </div>
            ))}
          </div>
        </aside>

        <div class="lg:col-span-2">
          <h2 class="font-serif text-2xl font-semibold text-primary mb-6">Arquivo Digital</h2>
          
          <!-- Dimension Tabs -->
          <div class="flex gap-1 mb-4 border-b border-subtle pb-4 overflow-x-auto">
            {dimensions.map((dim) => (
              <button 
                data-dim={dim.id}
                class="dim-tab px-4 py-2 text-sm font-medium rounded-t-md transition-colors whitespace-nowrap"
              >
                {dim.name}
              </button>
            ))}
          </div>

          <!-- Sub-filters (dynamic) -->
          <div id="sub-filters-container" class="flex gap-2 mb-6 flex-wrap">
            <!-- Populated by JS -->
          </div>

          <!-- Content Grid -->
          <div id="content-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <!-- Populated by JS -->
          </div>
        </div>
      </div>
    </div>
  </section>

  <script define:vars={{ 
    dimensions, 
    archiveVideos, 
    canalVideos, 
    outroVideos,
    dimIItems,
    dimIIIItems,
    dimIVItems,
    getVideoThumbnailUrl,
    getVideoYoutubeUrl,
    formatViews
  }}>
    const tabs = document.querySelectorAll('.dim-tab');
    const subFiltersContainer = document.getElementById('sub-filters-container');
    const contentGrid = document.getElementById('content-grid');

    let activeDim = 'II';
    let activeSubFilter = 'canal';

    // Get video items for Dim II
    const videoItems = [...archiveVideos].sort((a, b) => b.views - a.views);

    function renderSubFilters(dimId) {
      const dim = dimensions.find(d => d.id === dimId);
      if (!dim || dim.subfilters.length === 0) {
        subFiltersContainer.innerHTML = '';
        return;
      }

      const activeFilter = getActiveFilterForDim(dimId);
      
      subFiltersContainer.innerHTML = dim.subfilters.map(sf => `
        <button 
          data-subfilter="${sf.id}" 
          class="sub-tab px-3 py-1.5 text-xs font-medium rounded-full transition-colors ${sf.id === activeFilter ? 'bg-primary/10 text-primary' : 'bg-surface text-secondary hover:text-primary'}"
        >
          ${sf.label} (${sf.count})
        </button>
      `).join('');

      // Add click handlers
      subFiltersContainer.querySelectorAll('.sub-tab').forEach(btn => {
        btn.addEventListener('click', () => {
          activeSubFilter = btn.dataset.subfilter;
          renderSubFilters(activeDim);
          renderContent(activeDim);
        });
      });
    }

    function getActiveFilterForDim(dimId) {
      if (dimId === 'II') {
        return activeSubFilter;
      }
      // For other dims, return first subfilter or none
      const dim = dimensions.find(d => d.id === dimId);
      return dim && dim.subfilters.length > 0 ? dim.subfilters[0].id : null;
    }

    function renderContent(dimId) {
      if (dimId === 'II') {
        // Videos
        let filtered = videoItems;
        if (activeSubFilter === 'canal') {
          filtered = canalVideos;
        } else if (activeSubFilter === 'outro') {
          filtered = outroVideos;
        }
        // All (activeSubFilter === 'todos') shows all

        contentGrid.innerHTML = filtered.map(video => `
          <a href="${getVideoYoutubeUrl(video)}" target="_blank" rel="noopener noreferrer" class="group bg-surface border border-subtle rounded-lg overflow-hidden hover:border-accent-nature/30">
            <div class="relative aspect-video bg-canvas">
              <img src="${getVideoThumbnailUrl(video)}" alt="${video.title}" loading="lazy" class="w-full h-full object-cover" onerror="this.src='/images/video-placeholder.svg'" />
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                <div class="w-12 h-12 rounded-full bg-white/90 flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
              <span class="absolute bottom-2 right-2 px-2 py-0.5 bg-black/70 text-white text-xs rounded">${video.duration}</span>
            </div>
            <div class="p-4">
              <h4 class="font-serif text-base font-medium text-primary mb-1 line-clamp-2">${video.title}</h4>
              <p class="text-xs text-secondary">${formatViews(video.views)} - ${video.year}</p>
            </div>
          </a>
        `).join('');

      } else if (dimId === 'I') {
        // Articles
        contentGrid.innerHTML = dimIItems.map(item => `
          <a href="${item.url}" target="_blank" rel="noopener noreferrer" class="group bg-surface border border-subtle rounded-lg p-4 hover:border-accent-nature/30">
            <span class="inline-block px-2 py-0.5 text-xs font-medium rounded bg-accent-nature/20 text-accent-nature mb-2">${item.type}</span>
            <h4 class="font-serif text-base font-medium text-primary mb-1 line-clamp-2">${item.title}</h4>
            <p class="text-xs text-secondary mb-1">${item.source}</p>
            ${item.description ? `<p class="text-xs text-secondary line-clamp-2">${item.description}</p>` : ''}
          </a>
        `).join('');

      } else if (dimId === 'III') {
        // Blogs/Crónicas
        contentGrid.innerHTML = dimIIIItems.map(item => `
          <a href="${item.url}" target="_blank" rel="noopener noreferrer" class="group bg-surface border border-subtle rounded-lg p-4 hover:border-accent-nature/30">
            <span class="inline-block px-2 py-0.5 text-xs font-medium rounded bg-accent-nature/20 text-accent-nature mb-2">${item.type}</span>
            <h4 class="font-serif text-base font-medium text-primary mb-1 line-clamp-2">${item.title}</h4>
            <p class="text-xs text-secondary mb-1">${item.source}</p>
            ${item.description ? `<p class="text-xs text-secondary line-clamp-2">${item.description}</p>` : ''}
          </a>
        `).join('');

      } else if (dimId === 'IV') {
        // Social posts
        contentGrid.innerHTML = dimIVItems.map(item => `
          <a href="${item.url}" target="_blank" rel="noopener noreferrer" class="group bg-surface border border-subtle rounded-lg p-4 hover:border-accent-nature/30">
            <span class="inline-block px-2 py-0.5 text-xs font-medium rounded ${item.type === 'facebook' ? 'bg-blue-500/20 text-blue-500' : 'bg-pink-500/20 text-pink-500'} mb-2">${item.type}</span>
            <h4 class="font-serif text-base font-medium text-primary mb-1 line-clamp-2">${item.title}</h4>
            <p class="text-xs text-secondary">${item.source}</p>
          </a>
        `).join('');
      }
    }

    function updateTabs() {
      tabs.forEach(tab => {
        if (tab.dataset.dim === activeDim) {
          tab.classList.add('bg-primary/10', 'text-primary');
          tab.classList.remove('text-secondary');
        } else {
          tab.classList.remove('bg-primary/10', 'text-primary');
          tab.classList.add('text-secondary');
        }
      });
    }

    function init() {
      // Set initial active tab
      activeDim = 'II';
      updateTabs();
      renderSubFilters(activeDim);
      renderContent(activeDim);

      // Tab click handlers
      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          activeDim = tab.dataset.dim;
          activeSubFilter = getDefaultSubFilter(activeDim);
          updateTabs();
          renderSubFilters(activeDim);
          renderContent(activeDim);
        });
      });
    }

    function getDefaultSubFilter(dimId) {
      if (dimId === 'II') return 'canal';
      if (dimId === 'I') return 'artigos';
      if (dimId === 'III') return 'blogs';
      return null;
    }

    init();
  </script>
</Layout>