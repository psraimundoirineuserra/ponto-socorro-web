---
import Layout from '@/layouts/Layout.astro';
import { useTranslations } from '@/i18n';
import FeaturedVideos from '@/components/archive/FeaturedVideos.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'pt' } },
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang as 'pt' | 'es' | 'en');

const translations = {
  pt: {
    title: 'Arquivo',
    subtitle: 'Preservação e Memória',
    timeline: {
      title: 'O Fio da Memória',
      nodes: [
        { year: '2007', title: 'Fundação e Relato', desc: 'Chegada à Vila Carneiro e crónicas de O Peregrino' },
        { year: '2011', title: 'Expansão Doutrinal', desc: 'Consolidação de blogs e registros do Padrinho Nonato' },
        { year: '2012', title: 'Ano Acadêmico', desc: 'Tese USP sobre controvérsia ayahuasca e registros em Acre' },
        { year: '2016', title: 'Crescimento Digital', desc: 'Digitalização de calendários e expansão em redes sociais' },
        { year: '2022', title: 'Consolidação Territorial', desc: 'Censo Comunitário da Colônia Cinco Mil' },
        { year: '2023-25', title: 'Presente/Evolução', desc: 'Estudos etnográficos e processos contemporâneos' }
      ]
    },
    dimensions: {
      i: 'O Trono do Saber',
      ii: 'A Memória Viva',
      iii: 'O Olhar da Floresta',
      iv: 'A Bitácora Digital'
    },
    videos: {
      title: 'Videos',
      viewsLabel: 'visualizações',
      watchOn: 'Ver no YouTube'
    }
  },
  es: {
    title: 'Archivo',
    subtitle: 'Preservación y Memoria',
    timeline: {
      title: 'El Hilo de la Memoria',
      nodes: [
        { year: '2007', title: 'Fundación y Relato', desc: 'Llegada a Vila Carneiro y crónicas de O Peregrino' },
        { year: '2011', title: 'Expansión Doctrinal', desc: 'Consolidación de blogs y registros de Padrinho Nonato' },
        { year: '2012', title: 'Año Académico', desc: 'Tesis USP sobre controversia ayahuasca y registros en Acre' },
        { year: '2016', title: 'Crecimiento Digital', desc: 'Digitalización de calendarios y expansión en redes sociales' },
        { year: '2022', title: 'Consolidación Territorial', desc: 'Censo Comunitario de Colônia Cinco Mil' },
        { year: '2023-25', title: 'Presente/Evolución', desc: 'Estudios etnográficos y procesos contemporáneos' }
      ]
    },
    dimensions: {
      i: 'El Trono del Saber',
      ii: 'La Memoria Viva',
      iii: 'La Mirada de la Selva',
      iv: 'La Bitácora Digital'
    },
    videos: {
      title: 'Videos',
      viewsLabel: 'visualizaciones',
      watchOn: 'Ver en YouTube'
    }
  },
  en: {
    title: 'Archive',
    subtitle: 'Preservation and Memory',
    timeline: {
      title: 'The Thread of Memory',
      nodes: [
        { year: '2007', title: 'Founding and Narrative', desc: 'Arrival at Vila Carneiro and O Peregrino chronicles' },
        { year: '2011', title: 'Doctrinal Expansion', desc: 'Blog consolidation and Padrinho Nonato records' },
        { year: '2012', title: 'Academic Year', desc: 'USP thesis on ayahuasca controversy and Acre records' },
        { year: '2016', title: 'Digital Growth', desc: 'Calendar digitization and social media expansion' },
        { year: '2022', title: 'Territorial Consolidation', desc: 'Community Census of Colônia Cinco Mil' },
        { year: '2023-25', title: 'Present/Evolution', desc: 'Ethnographic studies and contemporary processes' }
      ]
    },
    dimensions: {
      i: 'The Throne of Knowledge',
      ii: 'Living Memory',
      iii: 'The Eyes of the Forest',
      iv: 'The Digital Logbook'
    },
    videos: {
      title: 'Videos',
      viewsLabel: 'views',
      watchOn: 'Watch on YouTube'
    }
  }
};

const content = translations[lang as keyof typeof translations];
---

<Layout locale={lang} title={content.title} description={content.subtitle}>
  <section class="py-16 px-6">
    <div class="max-w-6xl mx-auto">
      <header class="mb-16">
        <h1 class="font-serif text-4xl md:text-5xl font-semibold text-primary mb-4">
          {content.title}
        </h1>
        <p class="text-lg text-secondary">
          {content.subtitle}
        </p>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <aside class="lg:col-span-1">
          <h2 class="text-xs font-medium uppercase tracking-wider text-secondary mb-6">
            {content.timeline.title}
          </h2>
          
          <div class="relative pl-6 border-l border-subtle">
            {content.timeline.nodes.map((node, i) => (
              <div class="relative mb-8 last:mb-0">
                <div class={`absolute -left-[13px] w-3 h-3 rounded-full bg-canvas border-2 ${i === 2 ? 'border-accent-nature' : 'border-primary'}`}></div>
                <p class="text-xs font-medium text-accent-nature mb-1">{node.year}</p>
                <h3 class="font-serif text-lg font-medium text-primary mb-1">{node.title}</h3>
                <p class="text-sm text-secondary">{node.desc}</p>
              </div>
            ))}
          </div>
        </aside>

        <div class="lg:col-span-2">
          <div class="mb-12">
            <h2 class="font-serif text-2xl font-semibold text-primary mb-6">
              {content.videos.title}
            </h2>
            <FeaturedVideos activeDimension="II" />
          </div>

          <div class="mb-12">
            <div class="flex flex-wrap gap-4 mb-6">
              <span class="px-3 py-1 text-xs font-medium bg-surface border border-subtle rounded-full text-secondary">
                {content.dimensions.i}
              </span>
              <span class="px-3 py-1 text-xs font-medium bg-accent-nature/10 border border-accent-nature/30 rounded-full text-accent-nature">
                {content.dimensions.ii}
              </span>
              <span class="px-3 py-1 text-xs font-medium bg-surface border border-subtle rounded-full text-secondary">
                {content.dimensions.iii}
              </span>
              <span class="px-3 py-1 text-xs font-medium bg-surface border border-subtle rounded-full text-secondary">
                {content.dimensions.iv}
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>