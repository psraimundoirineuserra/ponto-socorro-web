---
import Layout from '@/layouts/Layout.astro';
import ProductGrid from '@/components/shop/ProductGrid.astro';
import { useTranslations } from '@/i18n';
import { products } from '@/data/products';

export function getStaticPaths() {
  return [
    // Portuguese - both /shop and /loja
    { params: { lang: 'pt', '*': 'shop' } },
    { params: { lang: 'pt', '*': 'loja' } },
    // Spanish - both /shop and /tienda
    { params: { lang: 'es', '*': 'shop' } },
    { params: { lang: 'es', '*': 'tienda' } },
    // English - only /shop (standard)
    { params: { lang: 'en', '*': 'shop' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang as 'pt' | 'es' | 'en');
---

<Layout locale={lang} title="Shop" description="Ponto Socorro Shop">
  <section class="py-16 px-6">
    <div class="max-w-6xl mx-auto">
      <h1 class="font-serif text-4xl font-semibold text-primary mb-4">
        {t.nav.shop}
      </h1>
      <p class="text-secondary mb-12">
        {lang === 'pt' ? 'Textiles, instrumentos e publicações da comunidade' :
         lang === 'es' ? 'Textiles, instrumentos y publicaciones de la comunidad' :
         'Textiles, instruments and community publications'}
      </p>
      
      <ProductGrid products={products} />
    </div>
  </section>
</Layout>