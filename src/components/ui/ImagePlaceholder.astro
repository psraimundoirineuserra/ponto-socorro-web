---
interface Props {
  src?: string;
  alt: string;
  class?: string;
  aspectRatio?: 'square' | 'video' | 'portrait';
}

const { src, alt, class: className, aspectRatio = 'square' } = Astro.props;

const aspectClasses = {
  square: 'aspect-square',
  video: 'aspect-video',
  portrait: 'aspect-[3/4]',
};
---

{src ? (
  <img
    src={src}
    alt={alt}
    class:list={['object-cover w-full h-full', className]}
    loading="lazy"
  />
) : (
  <div
    class:list={[
      'bg-canvas flex items-center justify-center border border-subtle rounded',
      aspectClasses[aspectRatio],
      className,
    ]}
  >
    <div class="text-center text-secondary">
      <svg
        class="w-8 h-8 mx-auto mb-2 opacity-50"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
        />
      </svg>
      <p class="text-xs">{alt}</p>
    </div>
  </div>
)}
