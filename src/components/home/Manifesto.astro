---
import { useTranslations } from '@/i18n';

interface Props {
  locale: 'pt' | 'es' | 'en';
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const content = await import(`../../i18n/content/home/content-${locale}.json`).catch(() => {
  return import(`../../i18n/content/home/content-pt.json`);
});
---

<section class="py-32 px-6">
  <div class="max-w-2xl mx-auto">
    <h2 class="font-serif text-3xl md:text-4xl font-semibold text-primary mb-12">
      {content.default.manifesto.title}
    </h2>
    <div class="prose prose-lg text-secondary space-y-6" set:html={content.default.manifesto.body} />
  </div>
</section>
