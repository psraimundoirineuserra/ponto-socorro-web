---
import { useTranslations } from '@/i18n';

const t = useTranslations('es');
---

<section class="relative h-[80vh] flex items-center justify-center bg-canvas overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-surface via-canvas to-canvas"></div>

  <div class="relative z-10 text-center max-w-3xl px-6">
    <h1 class="font-serif text-5xl md:text-7xl font-semibold text-primary mb-6 tracking-tight">
      {t.home.hero.title}
    </h1>
    <p class="text-lg md:text-xl text-secondary mb-12 max-w-xl mx-auto">
      {t.home.hero.subtitle}
    </p>
    <a
      href="/library"
      class="inline-flex items-center gap-2 text-sm font-medium text-primary border border-subtle px-6 py-3 rounded-full hover:bg-surface transition-colors"
    >
      {t.home.hero.cta}
      <span>→</span>
    </a>
  </div>

  <div class="absolute bottom-12 left-1/2 -translate-x-1/2">
    <div class="w-px h-12 bg-gradient-to-b from-transparent to-secondary/30"></div>
  </div>
</section>
