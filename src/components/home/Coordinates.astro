---
import { useTranslations } from '@/i18n';
import { Star, Church, MapPin, Flower2 } from 'lucide-react';

interface Props {
  locale: 'pt' | 'es' | 'en';
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="py-24 px-6 bg-surface border-y border-subtle">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-xs font-medium uppercase tracking-wider text-secondary mb-12">
      {t.home.coordinates.title}
    </h2>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-12">
      <div>
        <div class="w-12 h-12 rounded-full bg-canvas flex items-center justify-center mb-4">
          <Star class="w-6 h-6 text-primary" />
        </div>
        <p class="font-serif text-4xl font-semibold text-primary">1966</p>
        <p class="text-sm text-secondary mt-2">{t.home.coordinates.mandato}</p>
      </div>

      <div>
        <div class="w-12 h-12 rounded-full bg-canvas flex items-center justify-center mb-4">
          <Church class="w-6 h-6 text-primary" />
        </div>
        <p class="font-serif text-4xl font-semibold text-primary">1997</p>
        <p class="text-sm text-secondary mt-2">{t.home.coordinates.founded}</p>
      </div>

      <div>
        <div class="w-12 h-12 rounded-full bg-canvas flex items-center justify-center mb-4">
          <MapPin class="w-6 h-6 text-primary" />
        </div>
        <p class="font-serif text-3xl font-semibold text-primary">Rio Branco</p>
        <p class="text-sm text-secondary mt-2">Acre, Brasil</p>
        <p class="text-xs text-secondary mt-1">{t.home.coordinates.location}</p>
      </div>

      <div>
        <div class="w-12 h-12 rounded-full bg-canvas flex items-center justify-center mb-4">
          <Flower2 class="w-6 h-6 text-primary" />
        </div>
        <p class="font-serif text-3xl font-semibold text-primary">Linha de Arrochim</p>
        <p class="text-sm text-secondary mt-2">{t.home.coordinates.cura}</p>
      </div>
    </div>
  </div>
</section>