---
import { useTranslations } from '@/i18n';

const t = useTranslations('es');
---

<section class="py-24 px-6 bg-surface border-y border-subtle">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-xs font-medium uppercase tracking-wider text-secondary mb-12">
      {t.home.coordinates.title}
    </h2>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-12">
      <div>
        <p class="font-serif text-4xl font-semibold text-primary">1987</p>
        <p class="text-sm text-secondary mt-2">{t.home.coordinates.founded}</p>
      </div>

      <div>
        <p class="font-serif text-4xl font-semibold text-primary">🌍</p>
        <p class="text-sm text-secondary mt-2">{t.home.coordinates.location}</p>
      </div>

      <div>
        <p class="font-serif text-4xl font-semibold text-primary">3</p>
        <p class="text-sm text-secondary mt-2">Idiomas</p>
      </div>

      <div>
        <p class="font-serif text-4xl font-semibold text-primary">∞</p>
        <p class="text-sm text-secondary mt-2">{t.home.coordinates.community}</p>
      </div>
    </div>
  </div>
</section>
