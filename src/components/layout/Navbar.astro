---
import { useTranslations, changeLanguage, languageNames } from '@/i18n';
import type { Locale } from '@/i18n';

const locale = Astro.props.locale as Locale || 'pt';
const t = useTranslations(locale);
const currentPath = Astro.url.pathname;

const navLinks = [
  { key: 'home', href: `/${locale}/` },
  { key: 'foundation', href: `/${locale}/foundation` },
  { key: 'library', href: `/${locale}/library` },
  { key: 'archive', href: `/${locale}/archive` },
  { key: 'shop', href: `/${locale}/shop` },
];
---

<header class="fixed top-0 left-0 right-0 z-50 h-16 backdrop-blur-md bg-surface/80 border-b border-subtle">
  <nav class="max-w-7xl mx-auto h-full px-6 flex items-center justify-between">
    <a href={navLinks[0].href} class="font-serif text-xl font-semibold tracking-tight text-primary">
      {t.common.brand}
    </a>

    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a 
          href={link.href} 
          class="text-sm font-medium text-secondary hover:text-primary transition-colors"
        >
          {t.nav[link.key as keyof typeof t.nav]}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-4">
      <div class="hidden md:flex items-center gap-2 text-xs">
        {(['es', 'en', 'pt'] as Locale[]).map((lang) => (
          <a
            href={changeLanguage(lang, currentPath)}
            class={`${lang === locale ? 'text-primary font-medium' : 'text-secondary hover:text-primary'} transition-colors`}
          >
            {lang.toUpperCase()}
          </a>
        ))}
      </div>

      <button 
        id="cart-btn"
        class="relative p-2 text-secondary hover:text-primary transition-colors"
        aria-label="Carrito"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        <span id="cart-count" class="absolute -top-1 -right-1 w-4 h-4 bg-accent-nature text-white text-xs rounded-full flex items-center justify-center hidden">0</span>
      </button>

      <button 
        id="mobile-menu-btn" 
        class="md:hidden p-2 text-secondary hover:text-primary transition-colors"
        aria-label="Menu"
        transition:persist="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-subtle bg-surface" transition:persist="mobile-menu">
    <div class="px-6 py-4 space-y-3">
      {navLinks.map((link) => (
        <a 
          href={link.href} 
          class="block text-sm font-medium text-secondary hover:text-primary transition-colors py-2"
        >
          {t.nav[link.key as keyof typeof t.nav]}
        </a>
      ))}
      <div class="flex items-center gap-4 pt-4 border-t border-subtle">
        {(['es', 'en', 'pt'] as Locale[]).map((lang) => (
          <a
            href={changeLanguage(lang, currentPath)}
            class={`${lang === locale ? 'text-primary font-medium' : 'text-secondary hover:text-primary'} text-sm transition-colors`}
          >
            {languageNames[lang]}
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<div class="h-16"></div>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
