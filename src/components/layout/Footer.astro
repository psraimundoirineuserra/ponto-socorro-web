---
import { useTranslations } from '@/i18n';
import type { Locale } from '@/i18n';

const locale = Astro.props.locale as Locale || 'pt';
const t = useTranslations(locale);

const currentYear = new Date().getFullYear();

const pageNames: Record<string, Record<Locale, string>> = {
  foundation: { pt: 'fundacao', es: 'fundacion', en: 'foundation' },
  library: { pt: 'hinarios', es: 'himnarios', en: 'library' },
  archive: { pt: 'arquivo', es: 'archivo', en: 'archive' },
  shop: { pt: 'loja', es: 'tienda', en: 'shop' },
};

const navLinks = [
  { key: 'home', href: `/${locale}/` },
  { key: 'foundation', href: `/${locale}/${pageNames.foundation[locale]}` },
  { key: 'library', href: `/${locale}/${pageNames.library[locale]}` },
  { key: 'archive', href: `/${locale}/${pageNames.archive[locale]}` },
  { key: 'shop', href: `/${locale}/${pageNames.shop[locale]}` },
];

const socialLinks = [
  { name: 'Facebook', href: 'https://www.facebook.com/ProntoSocorrroEspiritual/', icon: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z' },
  { name: 'Instagram', href: 'https://www.instagram.com/ps.raimundoirineuserra/', icon: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z' },
  { name: 'Google Maps', href: 'https://share.google/8FMQmaWrE8rfLZFtu', icon: 'M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z' },
];

const address = '010, KM04, Ramal 5, R. da Vila dos Carneiros, 000, Rio Branco - AC, Brasil';
---

<footer class="bg-surface border-t border-subtle">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div>
        <a href={`/${locale}/`} class="font-serif text-xl font-semibold tracking-tight text-primary block mb-4">
          CEPSERIS
        </a>
        <p class="text-sm text-secondary max-w-xs">
          Centro e Pronto Socorro Espiritual Raimundo Irineu Serra
        </p>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-secondary mb-6">
          {t.footer.navigation}
        </h4>
        <ul class="space-y-3">
          {navLinks.map((link) => (
            <li>
              <a 
                href={link.href} 
                class="text-sm text-secondary hover:text-primary transition-colors"
              >
                {t.nav[link.key as keyof typeof t.nav]}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-secondary mb-6">
          {t.footer.contact}
        </h4>
        <p class="text-sm text-secondary mb-4">
          {address}
        </p>
        <div class="flex gap-4">
          {socialLinks.map((social) => (
            <a 
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-secondary hover:text-primary transition-colors"
              aria-label={social.name}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="pt-8 mt-12 border-t border-subtle">
      <p class="text-xs text-secondary">
        {t.footer.copyright.replace('{year}', currentYear.toString())}
      </p>
    </div>
  </div>
</footer>