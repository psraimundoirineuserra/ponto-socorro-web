---
import { useTranslations } from '@/i18n';
import type { Locale } from '@/i18n';

const locale = Astro.props.locale as Locale || 'pt';
const t = useTranslations(locale);

const currentYear = new Date().getFullYear();

const navLinks = [
  { key: 'home', href: `/${locale}/` },
  { key: 'foundation', href: `/${locale}/foundation` },
  { key: 'library', href: `/${locale}/library` },
  { key: 'archive', href: `/${locale}/archive` },
  { key: 'shop', href: `/${locale}/shop` },
];
---

<footer class="bg-surface border-t border-subtle">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div>
        <a href={`/${locale}/`} class="font-serif text-xl font-semibold tracking-tight text-primary block mb-4">
          {t.common.brand}
        </a>
        <p class="text-sm text-secondary max-w-xs">
          {t.common.tagline}
        </p>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-secondary mb-6">
          {t.footer.navigation}
        </h4>
        <ul class="space-y-3">
          {navLinks.map((link) => (
            <li>
              <a 
                href={link.href} 
                class="text-sm text-secondary hover:text-primary transition-colors"
              >
                {t.nav[link.key as keyof typeof t.nav]}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-secondary mb-6">
          {t.footer.contact}
        </h4>
        <p class="text-sm text-secondary">
          {t.footer.email}
        </p>
      </div>
    </div>

    <div class="pt-8 mt-12 border-t border-subtle">
      <p class="text-xs text-secondary">
        {t.footer.copyright.replace('{year}', currentYear.toString())}
      </p>
    </div>
  </div>
</footer>
