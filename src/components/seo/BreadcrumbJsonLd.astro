---
interface Props {
  items: Array<{
    name: string;
    url: string;
  }>;
  locale?: 'pt' | 'es' | 'en';
}

const { items, locale = 'pt' } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': items.map((item, index) => ({
    '@type': 'ListItem',
    'position': index + 1,
    'name': item.name,
    'item': item.url
  }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />