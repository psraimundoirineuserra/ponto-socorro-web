---
const rawSiteUrl = Astro.site?.href || 'https://cepseris.org';
const siteUrl = rawSiteUrl.endsWith('/') ? rawSiteUrl.slice(0, -1) : rawSiteUrl;

const schema = {
  "@context": "https://schema.org",
  "@id": `${siteUrl}/#organization`,
  "@type": ["Organization", "Church"],
  "name": "Centro e Pronto Socorro Espiritual Raimundo Irineu Serra",
  "alternateName": ["CEPSERIS", "Pronto Socorro"],
  "url": `${siteUrl}/`,
  "logo": {
    "@type": "ImageObject",
    "url": `${siteUrl}/images/logo_prontosocorro.webp`
  },
  "image": `${siteUrl}/images/logo_prontosocorro.webp`,
  "description": "Igreja da Doutrina de Santo Daime. Himnários, cânticos e cura espiritual.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "010, KM04, Ramal 5, R. da Vila dos Carneiros, 000",
    "addressLocality": "Rio Branco",
    "addressRegion": "AC",
    "addressCountry": "BR"
  },
  "sameAs": [
    "https://www.facebook.com/ProntoSocorrroEspiritual/",
    "https://www.instagram.com/ps.raimundoirineuserra/",
    "https://share.google/8FMQmaWrE8rfLZFtu"
  ],
  "foundingDate": "1932",
  "founder": {
    "@type": "Person",
    "name": "Raimundo Irineu Serra"
  },
  "areaServed": "BR"
};

const schemaString = JSON.stringify(schema);
---

<script type="application/ld+json" set:html={schemaString} is:inline />